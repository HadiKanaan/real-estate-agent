# Streamlit frontend container for the Real Estate Agent.
# This Dockerfile creates an optimized image for running the Streamlit UI.
FROM python:3.11-slim

# Set working directory for the Streamlit app.
WORKDIR /app

# Install curl for container health checks.
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Copy only requirements first for layer caching optimization.
# Streamlit UI has minimal dependencies compared to backend.
COPY requirements.txt .

# Install dependencies without cache to reduce image size.
RUN pip install --no-cache-dir -r requirements.txt

# Copy the UI application and supporting files.
COPY ui ./ui

# Streamlit runs headless in containers and binds to all interfaces.
ENV STREAMLIT_SERVER_HEADLESS=true
ENV STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Use --logger.level=error to reduce log verbosity in production.
# Use --client.showErrorDetails=false to avoid exposing sensitive info.
EXPOSE 8501

# Health check: curl the Streamlit status endpoint to ensure container is running.
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD bash -lc 'curl -fsS "http://127.0.0.1:${PORT:-8501}/_stcore/health" || exit 1'

# Run Streamlit with config flags optimized for containerized production deployment.
CMD ["bash", "-lc", "streamlit run ui/streamlit_app.py --server.address 0.0.0.0 --server.port ${PORT:-8501} --logger.level=error --client.showErrorDetails=false --client.toolbarMode=minimal"]
