FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl bash && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app ./app
COPY ui ./ui
COPY start_railway.sh ./start_railway.sh
RUN chmod +x /app/start_railway.sh

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD bash -lc 'curl -fsS "http://127.0.0.1:${PORT:-8501}/_stcore/health" || exit 1'

CMD ["/app/start_railway.sh"]
